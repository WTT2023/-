#include <iostream>
#include <vector>
#include <cmath>
#include <fstream>
#include <memory>
#include <sstream>
#include <string>

constexpr double EPS = 1e-9;

struct Point {
    double x = 0.0;
    double y = 0.0;
};

class Geometry {
public:
    virtual ~Geometry() = default;
    virtual double area() const = 0;
    virtual bool contains(const Point& p) const = 0;
};

class Polygon : public Geometry {
public:
    explicit Polygon(const std::vector<Point>& pts) : vertices(pts) {}

    double area() const override {
        double sum = 0.0;
        size_t n = vertices.size();
        for (size_t i = 0; i < n; ++i) {
            const Point& p1 = vertices[i];
            const Point& p2 = vertices[(i + 1) % n];
            sum += (p1.x * p2.y - p2.x * p1.y);
        }
        return std::abs(sum) * 0.5;
    }

    bool contains(const Point& p) const override {
        bool inside = false;
        size_t n = vertices.size();
        for (size_t i = 0, j = n - 1; i < n; j = i++) {
            const Point& pi = vertices[i];
            const Point& pj = vertices[j];

            // Check if point is on edge
            double cross = (pj.x - pi.x) * (p.y - pi.y) - (pj.y - pi.y) * (p.x - pi.x);
            if (std::abs(cross) < EPS) {
                double dot = (p.x - pi.x) * (p.x - pj.x) + (p.y - pi.y) * (p.y - pj.y);
                if (dot <= EPS) return true;
            }

            bool intersect = ((pi.y > p.y) != (pj.y > p.y)) &&
                (p.x < (pj.x - pi.x) * (p.y - pi.y) / (pj.y - pi.y + EPS) + pi.x);
            if (intersect)
                inside = !inside;
        }
        return inside;
    }

private:
    std::vector<Point> vertices;
};

class BufferZone {
public:
    BufferZone(Point c, double r) : center(c), radius(r) {}

    bool contains(const Point& p) const {
        double dx = p.x - center.x;
        double dy = p.y - center.y;
        return (dx * dx + dy * dy) <= radius * radius + EPS;
    }

private:
    Point center;
    double radius;
};

std::unique_ptr<Geometry> loadGeometry(const std::string& path) {
    std::ifstream file(path);
    if (!file.is_open()) {
        throw std::runtime_error("Failed to open file");
    }

    std::string type;
    std::getline(file, type);

    if (type == "POLYGON") {
        size_t n;
        file >> n;
        std::vector<Point> pts(n);
        for (size_t i = 0; i < n; ++i) {
            file >> pts[i].x >> pts[i].y;
        }
        return std::make_unique<Polygon>(pts);
    }

    throw std::runtime_error("Unsupported geometry type");
}

int main() {
    try {
        auto geom = loadGeometry("polygon.txt");
        std::cout << "Polygon area: " << geom->area() << std::endl;

        Point testPoint{5, 5};
        std::cout << "Point inside polygon: "
                  << (geom->contains(testPoint) ? "YES" : "NO") << std::endl;

        BufferZone buffer({0, 0}, 5.0);
        std::cout << "Point inside buffer: "
                  << (buffer.contains(testPoint) ? "YES" : "NO") << std::endl;

    } catch (const std::exception& ex) {
        std::cerr << "Error: " << ex.what() << std::endl;
    }

    return 0;
}
